#!/usr/bin/env bash
# Post-commit: launch evaluator agent in background on main branch only.
# Does NOT block the commit — exits immediately after forking.
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
if [ "$BRANCH" = "main" ]; then
  REPO_ROOT="$(git rev-parse --show-toplevel)"
  nohup bash "$REPO_ROOT/scripts/run-evaluator.sh" >> /tmp/clawops-evaluator.log 2>&1 &
  echo "[post-commit] evaluator started (log: /tmp/clawops-evaluator.log)"
fi
