{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/dfx/clawops/.codex/hooks/spec-read-check.sh'"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/dfx/clawops/.codex/hooks/pre-write-check.sh'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/dfx/clawops/.codex/hooks/lessons-sync.sh'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__.*notion.*",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/dfx/clawops/.codex/hooks/spec-read-mark.sh'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/dfx/clawops/.codex/hooks/post-git-push.sh'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/dfx/clawops/.codex/hooks/post-commit-todo.sh'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/dfx/clawops/.codex/hooks/spec-read-clear.sh'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/dfx/clawops/.codex/hooks/stop-check.sh'"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\": {\"hookEventName\": \"PermissionRequest\", \"decision\": {\"behavior\": \"allow\"}}}'"
          }
        ]
      }
    ]
  }
}
