# ClawOps 環境変数テンプレート
# このファイルを .env.local にコピーして値を設定してください
# cp .env.example .env.local
#
# ⚠️ 注意: service_role キーは絶対にここに書かないこと
# service_role はサーバー側（Edge Function）でのみ使用する

# Supabase 接続情報
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry エラー監視 (任意、未設定時は無効)
VITE_SENTRY_DSN=

# J-INFRA-DUAL-TRACK-LOGIN-01: テスト版 (別デプロイ) の URL
# 設定するとログイン直後に「安定版/テスト版」選択画面を表示する。
# 未設定なら選択画面を出さず従来通り直接ランチャーへ遷移する。
# 例: Vercel の ocr-unify-01 branch alias
#   VITE_TEST_TRACK_URL=https://clawops-git-ocr-unify-01-xxxx.vercel.app
VITE_TEST_TRACK_URL=
